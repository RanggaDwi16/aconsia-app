rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------
    // Helpers
    // ----------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return isSignedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : null;
    }

    function isPasien() {
      return role() == 'pasien';
    }

    function isDokter() {
      return role() in ['dokter', 'doctor'];
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isSystem() {
      return request.auth.token.firebase.sign_in_provider == 'custom';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function emailValid(email) {
      return email is string
        && email.size() >= 6
        && email.size() <= 120
        && email.matches('^[^@ ]+@[^@ ]+\\.[^@ ]+$');
    }

    function phoneValid(phone) {
      return phone is string && phone.matches('^(\\+62|62|0)[0-9]{9,12}$');
    }

    function licenseTextValid(value) {
      return value is string
        && value.size() >= 1
        && value.size() <= 80;
    }

    function nonEmptyText(value, minSize, maxSize) {
      return value is string && value.size() >= minSize && value.size() <= maxSize;
    }

    function ownerHasStoredDokterRole(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.role in ['dokter', 'doctor'];
    }

    function isDokterLike() {
      return isDokter() || (isSignedIn() && ownerHasStoredDokterRole(request.auth.uid));
    }

    function doctorUserDocShapeValid(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'name',
          'displayName',
          'role',
          'status',
          'phone',
          'hospital',
          'specialization',
          'sipNumber',
          'strNumber',
          'isProfileCompleted',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.role == 'dokter'
        && request.resource.data.status == 'active'
        && request.resource.data.specialization == 'Anestesiologi'
        && request.resource.data.isProfileCompleted == true
        && emailValid(request.resource.data.email)
        && nonEmptyText(request.resource.data.name, 3, 80)
        && nonEmptyText(request.resource.data.displayName, 3, 80)
        && phoneValid(request.resource.data.phone)
        && nonEmptyText(request.resource.data.hospital, 3, 120)
        && licenseTextValid(request.resource.data.sipNumber)
        && licenseTextValid(request.resource.data.strNumber);
    }

    function doctorProfileDocShapeValid(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'fullName',
          'nama',
          'phoneNumber',
          'noTelepon',
          'hospitalName',
          'namaRumahSakit',
          'specialization',
          'sipNumber',
          'strNumber',
          'fotoProfilUrl',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.status == 'active'
        && request.resource.data.specialization == 'Anestesiologi'
        && emailValid(request.resource.data.email)
        && nonEmptyText(request.resource.data.fullName, 3, 80)
        && nonEmptyText(request.resource.data.nama, 3, 80)
        && request.resource.data.fullName == request.resource.data.nama
        && phoneValid(request.resource.data.phoneNumber)
        && request.resource.data.phoneNumber == request.resource.data.noTelepon
        && nonEmptyText(request.resource.data.hospitalName, 3, 120)
        && request.resource.data.hospitalName == request.resource.data.namaRumahSakit
        && licenseTextValid(request.resource.data.sipNumber)
        && licenseTextValid(request.resource.data.strNumber)
        && (
          !('fotoProfilUrl' in request.resource.data)
          || (
            request.resource.data.fotoProfilUrl is string
            && request.resource.data.fotoProfilUrl.size() <= 500
          )
        );
    }

    function userLifecycleNotChanged() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
        'status',
        'statusReason',
        'statusUpdatedAt',
        'statusUpdatedByUid'
      ]);
    }

    function isAdminOrSystem() {
      return isAdmin() || isSystem();
    }

    function pasienAssignedDokterId(data) {
      return ('dokterId' in data && data.dokterId is string && data.dokterId.size() > 0)
        ? data.dokterId
        : (
          ('assignedDokterId' in data && data.assignedDokterId is string && data.assignedDokterId.size() > 0)
            ? data.assignedDokterId
            : null
        );
    }

    function dokterNotChangingSensitivePasienFields() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
        'status',
        'approvalDate',
        'rejectionDate',
        'rejectionReason',
        'approvedByUid',
        'approvedByRole',
        'rejectedByUid',
        'rejectedByRole'
      ]);
    }

    function kontenModerationFieldsNotChanged() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
        'status',
        'publishedAt',
        'moderationReason',
        'moderatedByUid',
        'moderatedByRole',
        'moderatedAt'
      ]);
    }

    function adminKontenModerationUpdateValid() {
      return isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'publishedAt',
          'moderationReason',
          'moderatedByUid',
          'moderatedByRole',
          'moderatedAt',
          'updatedAt'
        ])
        && request.resource.data.status in ['draft', 'published']
        && request.resource.data.moderatedByUid == request.auth.uid
        && request.resource.data.moderatedByRole == 'admin'
        && request.resource.data.moderationReason is string
        && request.resource.data.moderationReason.size() >= 1
        && request.resource.data.moderationReason.size() <= 200
        && request.resource.data.moderatedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          (request.resource.data.status == 'published' && request.resource.data.publishedAt is timestamp)
          || (request.resource.data.status == 'draft' && request.resource.data.publishedAt == null)
        );
    }

    function assignmentReadableByDokter(assignData) {
      return isDokterLike() && (assignData.assignedBy == request.auth.uid || assignData.dokterId == request.auth.uid);
    }

    function chatParticipant(sessionData) {
      return isSignedIn() && (sessionData.pasienId == request.auth.uid || sessionData.dokterId == request.auth.uid);
    }

    function adminAuditClientCreateValid() {
      return request.resource.data.keys().hasOnly([
          'actorUid',
          'actorRole',
          'actorName',
          'actionType',
          'entityType',
          'entityId',
          'message',
          'status',
          'meta',
          'createdAt',
          'userId',
          'userRole',
          'userName',
          'action',
          'target',
          'details',
          'timestamp'
        ])
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.actorRole == 'admin'
        && request.resource.data.userRole == 'admin'
        && request.resource.data.status in ['success', 'failed']
        && request.resource.data.createdAt is timestamp
        && request.resource.data.timestamp is string
        && request.resource.data.timestamp.size() >= 10
        && request.resource.data.timestamp.size() <= 80
        && nonEmptyText(request.resource.data.actorName, 1, 120)
        && nonEmptyText(request.resource.data.actionType, 1, 80)
        && nonEmptyText(request.resource.data.entityType, 1, 80)
        && nonEmptyText(request.resource.data.userName, 1, 120)
        && nonEmptyText(request.resource.data.action, 1, 80)
        && nonEmptyText(request.resource.data.target, 1, 120)
        && nonEmptyText(request.resource.data.details, 1, 500)
        && nonEmptyText(request.resource.data.message, 1, 500);
    }

    // ----------------------
    // users
    // ----------------------
    match /users/{uid} {
      allow create: if
        isAdminOrSystem()
        || (
          isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.email is string
          && request.resource.data.role in ['pasien', 'dokter']
          && !('permissions' in request.resource.data)
          && !('hospitalId' in request.resource.data)
          && (
            !('status' in request.resource.data)
            || request.resource.data.status == 'active'
          )
          && (
            request.resource.data.role != 'dokter'
            || doctorUserDocShapeValid(uid)
          )
        );

      allow read: if isOwner(uid) || isAdminOrSystem();

      allow update: if
        // user update own non-sensitive fields only
        (isOwner(uid)
          && !('role' in request.resource.data.diff(resource.data).changedKeys())
          && !('status' in request.resource.data.diff(resource.data).changedKeys())
          && !('permissions' in request.resource.data.diff(resource.data).changedKeys())
          && !('hospitalId' in request.resource.data.diff(resource.data).changedKeys())
          && (
            resource.data.role != 'dokter'
            || doctorUserDocShapeValid(uid)
          ))
        || (isAdminOrSystem() && (isSystem() || userLifecycleNotChanged()));

      allow delete: if isOwner(uid) || isAdminOrSystem();
    }

    // ----------------------
    // profiles
    // ----------------------
    match /pasien_profiles/{uid} {
      allow create: if isOwner(uid) && isPasien() || isAdminOrSystem();

      allow read: if
        (isOwner(uid) && isPasien())
        || isAdminOrSystem()
        || (isDokterLike() && pasienAssignedDokterId(resource.data) == request.auth.uid);

      allow update: if
        // pasien update own profile
        (isOwner(uid) && isPasien())
        // dokter update pasien in scope
        || (
          isDokterLike()
          && pasienAssignedDokterId(resource.data) == request.auth.uid
          && dokterNotChangingSensitivePasienFields()
        )
        || isAdminOrSystem();

      allow delete: if isAdminOrSystem();
    }

    match /dokter_profiles/{uid} {
      allow create: if
        isAdminOrSystem()
        || (
          isOwner(uid)
          && (isDokter() || ownerHasStoredDokterRole(uid))
          && doctorProfileDocShapeValid(uid)
        );

      allow read: if
        (isOwner(uid) && (isDokter() || ownerHasStoredDokterRole(uid)))
        || isAdminOrSystem()
        || (
          isPasien() &&
          exists(/databases/$(database)/documents/pasien_profiles/$(request.auth.uid)) &&
          pasienAssignedDokterId(get(/databases/$(database)/documents/pasien_profiles/$(request.auth.uid)).data) == uid
        );

      allow update: if
        isAdminOrSystem()
        || (
          isOwner(uid)
          && (isDokter() || ownerHasStoredDokterRole(uid))
          && doctorProfileDocShapeValid(uid)
        );
      allow delete: if isAdminOrSystem();
    }

    match /public_dokter_options/{uid} {
      allow read: if true;
      allow create, update, delete: if isAdminOrSystem();
    }

    // ----------------------
    // konten + sections
    // ----------------------
    match /konten/{kontenId} {
      allow create: if isDokterLike() || isAdminOrSystem();

      allow read: if
        isAdminOrSystem()
        || isDokterLike()
        || (
          isPasien() &&
          (
            resource.data.status == 'published'
            || exists(/databases/$(database)/documents/assignments/$(kontenId + '_' + request.auth.uid))
          )
        );

      allow update: if
        adminKontenModerationUpdateValid()
        || 
        (isAdminOrSystem() && (isSystem() || kontenModerationFieldsNotChanged()))
        || (isDokterLike() && resource.data.dokterId == request.auth.uid && kontenModerationFieldsNotChanged());

      allow delete: if
        isAdminOrSystem()
        || (isDokterLike() && resource.data.dokterId == request.auth.uid);

      match /sections/{sectionId} {
        allow read: if
          isAdminOrSystem()
          || isDokterLike()
          || isPasien();

        allow create, update, delete: if
          isAdminOrSystem()
          || (
            isDokterLike()
            && exists(/databases/$(database)/documents/konten/$(kontenId))
            && get(/databases/$(database)/documents/konten/$(kontenId)).data.dokterId == request.auth.uid
          );
      }
    }

    // ----------------------
    // assignments
    // ----------------------
    match /assignments/{assignmentId} {
      allow create, delete: if isAdminOrSystem();

      allow read: if
        isAdminOrSystem()
        || (isPasien() && resource.data.pasienId == request.auth.uid)
        || assignmentReadableByDokter(resource.data);

      allow update: if
        isAdminOrSystem()
        || (
          isPasien()
          && resource.data.pasienId == request.auth.uid
          && request.resource.data.pasienId == resource.data.pasienId
          && request.resource.data.assignedBy == resource.data.assignedBy
          && request.resource.data.kontenId == resource.data.kontenId
        )
        || assignmentReadableByDokter(resource.data);
    }

    // ----------------------
    // reading sessions
    // ----------------------
    match /reading_sessions/{sessionId} {
      allow create: if
        isAdminOrSystem()
        || (isPasien() && request.resource.data.pasienId == request.auth.uid);

      allow read: if
        isAdminOrSystem()
        || (isPasien() && resource.data.pasienId == request.auth.uid)
        || (isDokterLike() && resource.data.dokterId == request.auth.uid);

      allow update: if
        isAdminOrSystem()
        || (isPasien() && resource.data.pasienId == request.auth.uid);

      allow delete: if isAdminOrSystem();
    }

    // ----------------------
    // quiz results
    // ----------------------
    match /quiz_results/{resultId} {
      allow create: if
        isAdminOrSystem()
        || (isPasien() && request.resource.data.pasienId == request.auth.uid);

      allow read: if
        isAdminOrSystem()
        || (isPasien() && resource.data.pasienId == request.auth.uid)
        || (isDokterLike() && resource.data.dokterId == request.auth.uid);

      allow update: if isAdminOrSystem();
      allow delete: if isAdminOrSystem();
    }

    // ----------------------
    // chat sessions + messages
    // ----------------------
    match /chat_sessions/{sessionId} {
      allow create: if
        isAdminOrSystem()
        || (
          isSignedIn()
          && request.resource.data.pasienId != null
          && request.resource.data.dokterId != null
          && (request.resource.data.pasienId == request.auth.uid || request.resource.data.dokterId == request.auth.uid)
        );

      allow read: if isAdminOrSystem() || chatParticipant(resource.data);

      allow update: if isAdminOrSystem() || chatParticipant(resource.data);
      allow delete: if isAdminOrSystem();

      match /messages/{messageId} {
        allow create: if
          isAdminOrSystem()
          || (
            isSignedIn()
            && exists(/databases/$(database)/documents/chat_sessions/$(sessionId))
            && chatParticipant(get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data)
            && request.resource.data.senderId == request.auth.uid
          );

        allow read: if
          isAdminOrSystem()
          || (
            isSignedIn()
            && exists(/databases/$(database)/documents/chat_sessions/$(sessionId))
            && chatParticipant(get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data)
          );

        allow update: if
          isAdminOrSystem()
          || (
            isSignedIn()
            && exists(/databases/$(database)/documents/chat_sessions/$(sessionId))
            && chatParticipant(get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data)
          );

        allow delete: if
          isAdminOrSystem()
          || (isSignedIn() && resource.data.senderId == request.auth.uid);
      }
    }

    // ----------------------
    // notifications
    // ----------------------
    match /notifications/{notificationId} {
      allow create: if isAdminOrSystem();

      allow read, update, delete: if
        isAdminOrSystem()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ----------------------
    // audit logs (immutable)
    // ----------------------
    match /admin_audit_logs/{logId} {
      allow create: if isSystem() || (isAdmin() && adminAuditClientCreateValid());
      allow read: if isAdminOrSystem();
      allow update, delete: if false;
    }

    // ----------------------
    // fallback deny
    // ----------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
