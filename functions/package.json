{
  "name": "aconsia-firebase-functions",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test:rules": "npx firebase emulators:exec --only firestore \"node --test tests/firestore.rules.test.js\"",
    "create:admin": "node scripts/create-admin-user.js",
    "seed:bootstrap": "node scripts/bootstrap-initial-data.js",
    "db:normalize-contract": "node scripts/normalize-mobile-web-contract.js",
    "db:backfill-quiz-dokter-id": "node scripts/backfill-quiz-results-dokter-id.js",
    "db:backfill-comprehension-from-quiz": "node scripts/backfill-pasien-comprehension-from-quiz.js",
    "db:audit-pasien-schedule": "node scripts/audit-pasien-profile-schedule-anomalies.js",
    "db:cleanup-draft-assignments": "node scripts/cancel-draft-assignments.js",
    "db:sync-public-dokter-options": "node scripts/sync-public-dokter-options.js",
    "auth:sync-dokter-claims": "node scripts/sync-dokter-role-claims.js",
    "auth:sync-pasien-claims": "node scripts/sync-pasien-role-claims.js"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.4.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "firebase": "^12.11.0",
    "firebase-tools": "^15.12.0"
  }
}
